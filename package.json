{
    "name": "x-m32-mcp-server",
    "version": "3.2.0",
    "description": "MCP server for controlling Behringer X32/M32 digital mixing consoles via OSC",
    "license": "MIT",
    "author": "Beomsu Koh",
    "homepage": "https://github.com/GoBeromsu/X32-MCP",
    "bugs": "https://github.com/GoBeromsu/X32-MCP/issues",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/GoBeromsu/X32-MCP.git"
    },
    "main": "dist/index.js",
    "type": "module",
    "bin": {
        "x-m32-mcp-server": "dist/index.js"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "modelcontextprotocol",
        "mcp",
        "x32",
        "m32",
        "behringer",
        "osc",
        "mixer",
        "audio",
        "live-sound"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "fetch:spec-types": "tsx scripts/fetch-spec-types.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "tsc -p tsconfig.prod.json",
        "build:watch": "tsc -p tsconfig.prod.json -w",
        "examples:simple-server:w": "tsx --watch src/examples/server/simpleStreamableHttp.ts --oauth",
        "prepack": "npm run build",
        "lint": "eslint src/ && prettier --check .",
        "lint:fix": "eslint src/ --fix && prettier --write .",
        "check": "npm run typecheck && npm run lint",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "start": "npm run server",
        "server": "tsx watch --clear-screen=false scripts/cli.ts server",
        "client": "tsx scripts/cli.ts client",
        "x32:server": "tsx src/x32-server/index.ts",
        "x32:test": "tsx scripts/x32-e2e.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "ajv": "^8.18.0",
        "ajv-formats": "^3.0.1",
        "content-type": "^1.0.5",
        "cors": "^2.8.6",
        "cross-spawn": "^7.0.6",
        "eventsource": "^4.1.0",
        "eventsource-parser": "^3.0.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "osc": "^2.4.4",
        "pkce-challenge": "^6.0.0",
        "raw-body": "^3.0.2",
        "zod": "^3.23.8",
        "zod-to-json-schema": "^3.25.1"
    },
    "peerDependencies": {
        "@cfworker/json-schema": "^4.1.1"
    },
    "peerDependenciesMeta": {
        "@cfworker/json-schema": {
            "optional": true
        }
    },
    "devDependencies": {
        "@cfworker/json-schema": "^4.1.1",
        "@eslint/js": "^9.39.4",
        "@jest-mock/express": "^3.0.0",
        "@types/content-type": "^1.1.9",
        "@types/cors": "^2.8.19",
        "@types/cross-spawn": "^6.0.6",
        "@types/eslint__js": "^8.42.3",
        "@types/eventsource": "^1.1.15",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.12",
        "@types/node": "^22.19.15",
        "@types/supertest": "^6.0.3",
        "@types/ws": "^8.18.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "jest": "^29.7.0",
        "prettier": "^3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.57.0",
        "ws": "^8.19.0"
    },
    "resolutions": {
        "strip-ansi": "6.0.1"
    },
    "overrides": {
        "brace-expansion": "1.1.12",
        "flatted": "3.4.1",
        "js-yaml": "3.14.2"
    }
}
